rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── USER DOCUMENTS ──
    // Allow users to read and write ONLY their own document (for Ante transactions, credits, XP)
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      // Allow user to update specific fields ONLY
      allow update: if isOwner(userId)
                    // PREVENT tier editing
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tier'])
                    // PREVENT xp inflation
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['xp'])
                    // PREVENT trial manipulation
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['trialEndsAt'])
                    // PREVENT manual collectible insertion
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['collectibles'])
                    // PREVENT Stripe ID manipulation
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stripeCustomerId']);
                    
      // Allow creation by the owner during first sign-up
      allow create: if isOwner(userId);
      allow delete: if false;

      // Subcollections
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /analytics/{analyticsId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }
    
    // ── SYSTEM STATUS ──
    // The useSystemStatus hook reads from config/system_status
    // Allow any authenticated user to read config collection
    match /config/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── GLOBAL STANDING ──
    // Allow any authenticated user to read global standings (leaderboards, rankings)
    match /global_standing/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── SYSTEM STATUS (legacy path) ──
    match /system_status/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── SYSTEM CONFIG (legacy path) ──
    match /system_config/{configId} {
      allow read: if true;
      allow write: if false;
    }

    match /stripe_webhooks_deadletter/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /leaderboards/{boardId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
